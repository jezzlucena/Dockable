<Window x:Class="Dockable.DockWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Dockable.ViewModels"
        xmlns:conv="clr-namespace:Dockable.Converters"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        Title="Dockable"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        AllowDrop="True"
        DragOver="OnDragOver"
        DragLeave="OnDragLeave"
        Drop="OnDrop"
        MouseRightButtonUp="Dock_RightClick">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:FallbackVisibilityConverter x:Key="FallbackVis" />
        <conv:LabelOpenConverter x:Key="LabelOpen" />
        <conv:AllTrueToVisibilityConverter x:Key="AllTrueToVis" />
        <conv:MultiplyConverter x:Key="Multiply" />

        <!-- Theme brushes (light defaults; ApplyTheme() swaps these at runtime for light/dark). -->
        <SolidColorBrush x:Key="BarBackgroundBrush" Color="#33FFFFFF" />
        <SolidColorBrush x:Key="BarBorderBrush" Color="#66FFFFFF" />
        <SolidColorBrush x:Key="SeparatorBrush" Color="#33000000" />
        <SolidColorBrush x:Key="RunningDotBrush" Color="#B3000000" />
        <SolidColorBrush x:Key="FallbackBgBrush" Color="#1F000000" />
        <SolidColorBrush x:Key="FallbackTextBrush" Color="#CC000000" />

        <!-- Hover label + Remove tag (themed in ApplyTheme; light defaults here). -->
        <SolidColorBrush x:Key="LabelBgBrush" Color="#F2F7F7FA" />
        <SolidColorBrush x:Key="LabelBorderBrush" Color="#22000000" />
        <SolidColorBrush x:Key="LabelTextBrush" Color="#1D1D1F" />

        <!-- Inner icon drop-shadow opacity (light default; subtle). ApplyTheme() swaps per theme. -->
        <sys:Double x:Key="IconShadowInnerOpacity">0.14</sys:Double>

        <!-- Outer icon drop-shadow: a swappable shared effect so Performance mode can drop the wide
             BlurRadius=20 pass (the biggest per-magnify-frame GPU cost). ApplyTheme() sets it per theme,
             or null when effects are reduced. -->
        <DropShadowEffect x:Key="IconOuterShadowEffect" BlurRadius="20" ShadowDepth="10" Direction="270" Opacity="0.10" Color="#000000" />

        <!-- One dock entry: Start logo for the Start item, otherwise an extracted icon.
             The container is sized/positioned by the layout engine (Width/Height/Canvas.Left/Top). -->
        <DataTemplate x:Key="DockItemTemplate" DataType="{x:Type vm:DockItemViewModel}">
            <Grid x:Name="ItemRoot"
                  Background="Transparent"
                  PreviewMouseLeftButtonDown="DockItem_PreviewMouseDown"
                  MouseLeftButtonUp="DockItem_Click"
                  PreviewMouseRightButtonUp="DockItem_RightClick">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <!-- Launcher icons use the regular arrow pointer (they're not links). Separators
                             show a resize cursor: up/down for a horizontal dock, left/right for a vertical one. -->
                        <Setter Property="Cursor" Value="Arrow" />
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsSeparator}" Value="True" />
                                    <Condition Binding="{Binding DataContext.IsVerticalDock, RelativeSource={RelativeSource AncestorType=Window}}" Value="False" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Cursor" Value="SizeNS" />
                            </MultiDataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsSeparator}" Value="True" />
                                    <Condition Binding="{Binding DataContext.IsVerticalDock, RelativeSource={RelativeSource AncestorType=Window}}" Value="True" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Cursor" Value="SizeWE" />
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <!-- Windows Start logo: four tiles, with a more pronounced drop shadow than the icons. -->
                <Viewbox Visibility="{Binding IsStartMenu, Converter={StaticResource BoolToVis}}">
                    <Viewbox.Effect>
                        <DropShadowEffect BlurRadius="12" ShadowDepth="2" Direction="270" Opacity="0.3" Color="#000000" />
                    </Viewbox.Effect>
                    <!-- Windows 11 logo, traced from Windows11.svg (viewBox 4875): four 2311-wide tiles
                         with a 253-unit gap (≈5.2%) and no outer margin. Fill keeps the dock's blue. -->
                    <Path Fill="#FF50B0F0"
                          Data="M0,0 H2311 V2310 H0 Z M2564,0 H4875 V2310 H2564 Z M0,2564 H2311 V4875 H0 Z M2564,2564 H4875 V4875 H2564 Z" />
                </Viewbox>

                <!-- Separator divider: a 2px line across the bar — vertical on a horizontal dock,
                     horizontal on a left/right dock (orientation comes from the view-model). -->
                <Rectangle Width="{Binding DataContext.SeparatorWidth, RelativeSource={RelativeSource AncestorType=Window}}"
                           Height="{Binding DataContext.SeparatorHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                           HorizontalAlignment="{Binding DataContext.SeparatorHAlign, RelativeSource={RelativeSource AncestorType=Window}}"
                           VerticalAlignment="{Binding DataContext.SeparatorVAlign, RelativeSource={RelativeSource AncestorType=Window}}"
                           RadiusX="1" RadiusY="1"
                           Fill="{DynamicResource SeparatorBrush}"
                           Visibility="{Binding IsSeparator, Converter={StaticResource BoolToVis}}" />

                <!-- Extracted icon (shortcuts) or window thumbnail (minimized tiles).
                     Two stacked drop-shadows (WPF allows one effect per element, so they're nested):
                     outer = 0 10 20 / 0.12, inner = 0 4 8 / 0.18. -->
                <Grid Visibility="{Binding ShowIconArea, Converter={StaticResource BoolToVis}}"
                      Effect="{DynamicResource IconOuterShadowEffect}">
                    <!-- Launch/attention bounce lifts only this icon (the running dot below stays put). -->
                    <Grid.RenderTransform>
                        <TranslateTransform X="{Binding BounceX}" Y="{Binding BounceY}" />
                    </Grid.RenderTransform>
                    <Image Source="{Binding Icon}"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality">
                        <Image.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="4" Direction="270" Opacity="{DynamicResource IconShadowInnerOpacity}" Color="#000000" />
                        </Image.Effect>
                    </Image>
                </Grid>

                <!-- Fallback while a shortcut icon is still loading -->
                <Border CornerRadius="10" Background="{DynamicResource FallbackBgBrush}">
                    <Border.Visibility>
                        <MultiBinding Converter="{StaticResource FallbackVis}">
                            <Binding Path="ShowIconArea" />
                            <Binding Path="Icon" />
                        </MultiBinding>
                    </Border.Visibility>
                    <TextBlock Text="{Binding DisplayName}"
                               Foreground="{DynamicResource FallbackTextBrush}"
                               FontSize="11"
                               TextAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center"
                               Margin="2" />
                </Border>

                <!-- App-icon badge on the bottom-right of a minimized-window thumbnail -->
                <Image Source="{Binding OverlayIcon}"
                       Width="20" Height="20"
                       HorizontalAlignment="Right" VerticalAlignment="Bottom"
                       Margin="0,0,1,1"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       Visibility="{Binding ShowOverlayIcon, Converter={StaticResource BoolToVis}}">
                    <Image.Effect>
                        <DropShadowEffect BlurRadius="4" ShadowDepth="0" Opacity="0.7" Color="#000000" />
                    </Image.Effect>
                </Image>

                <!-- Running indicator: a dot on the screen-edge side of the icon for open taskbar apps
                     (below for Bottom, above for Top, beside for Left/Right) — orientation from the VM. -->
                <Ellipse Width="4" Height="4"
                         VerticalAlignment="{Binding DataContext.DotVAlign, RelativeSource={RelativeSource AncestorType=Window}}"
                         HorizontalAlignment="{Binding DataContext.DotHAlign, RelativeSource={RelativeSource AncestorType=Window}}"
                         Margin="{Binding DataContext.DotMargin, RelativeSource={RelativeSource AncestorType=Window}}"
                         Fill="{DynamicResource RunningDotBrush}">
                    <Ellipse.Visibility>
                        <MultiBinding Converter="{StaticResource AllTrueToVis}">
                            <Binding Path="IsRunning" />
                            <Binding Path="DataContext.ShowRunningIndicators"
                                     RelativeSource="{RelativeSource AncestorType=Window}" />
                        </MultiBinding>
                    </Ellipse.Visibility>
                </Ellipse>

                <!-- Per-icon hover label: each icon owns its label, so moving between icons cross-fades
                     cleanly instead of swapping one shared popup's text (which "jumped"). It sits above
                     the icon (Bottom edge only), is themed via DynamicResource, and is click-through.
                     Starts transparent; the DataTemplate triggers fade it in/out on hover.

                     Hosted in a Canvas so it measures with unbounded width (long names like "Google
                     Chrome" aren't clipped to the narrow icon cell). It's centred over the icon by
                     placing it at half the icon width, then translated back by half its own width. -->
                <Canvas IsHitTestVisible="False">
                    <StackPanel x:Name="HoverLabel"
                                Canvas.Left="{Binding RenderWidth, Converter={StaticResource Multiply}, ConverterParameter=0.5}"
                                Canvas.Top="-39"
                                Opacity="0">
                        <StackPanel.RenderTransform>
                            <TranslateTransform X="{Binding ActualWidth, ElementName=HoverLabel, Converter={StaticResource Multiply}, ConverterParameter=-0.5}" />
                        </StackPanel.RenderTransform>
                        <StackPanel.Visibility>
                            <MultiBinding Converter="{StaticResource AllTrueToVis}">
                                <Binding Path="ShowLabel" />
                                <Binding Path="DataContext.HoverLabelsEnabled" RelativeSource="{RelativeSource AncestorType=Window}" />
                            </MultiBinding>
                        </StackPanel.Visibility>
                        <Border CornerRadius="7" Padding="10,4"
                                Background="{DynamicResource LabelBgBrush}"
                                BorderBrush="{DynamicResource LabelBorderBrush}" BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.4" Color="#000000" />
                            </Border.Effect>
                            <TextBlock Text="{Binding DisplayName}" Foreground="{DynamicResource LabelTextBrush}"
                                       FontSize="12" TextOptions.TextFormattingMode="Ideal" />
                        </Border>
                        <Path HorizontalAlignment="Center" Margin="0,-1.5,0,0"
                              Fill="{DynamicResource LabelBgBrush}" Data="M 0,0 L 14,0 L 7,7 Z" />
                    </StackPanel>
                </Canvas>
            </Grid>
            <DataTemplate.Triggers>
                <!-- Fade the hovered icon's label in; fade it out when the cursor leaves. -->
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="HoverLabel" Storyboard.TargetProperty="Opacity"
                                                 To="1" Duration="0:0:0.12" />
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="HoverLabel" Storyboard.TargetProperty="Opacity"
                                                 To="0" Duration="0:0:0.16" />
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <!-- Each item container is absolutely positioned and sized by the layout engine. -->
        <Style x:Key="DockItemContainerStyle" TargetType="ContentPresenter">
            <Setter Property="Canvas.Left" Value="{Binding X}" />
            <Setter Property="Canvas.Top" Value="{Binding Y}" />
            <Setter Property="Width" Value="{Binding RenderWidth}" />
            <Setter Property="Height" Value="{Binding RenderSize}" />
            <Style.Triggers>
                <!-- The hovered icon (and its label) render above neighbours so a long label isn't
                     covered by the next icon. -->
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Panel.ZIndex" Value="900" />
                </Trigger>
                <!-- While dragging, the in-canvas tile is hidden; the floating ghost popup
                     (which can roam outside the dock window) represents it. The slot stays
                     reserved as a gap so the others part. -->
                <DataTrigger Binding="{Binding IsDragging}" Value="True">
                    <Setter Property="Panel.ZIndex" Value="1000" />
                    <Setter Property="Opacity" Value="0" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Canvas x:Name="RootCanvas">
        <!-- Liquid Glass (real refraction): the captured backdrop behind the bar, refracted by a
             pixel shader (attached in code, gated on shader availability). Sits BEHIND DockBackground
             so the translucent bar + border render over it. Background is auto-clipped to the rounded
             corners. Click-through; shown only in LiquidGlass mode. -->
        <!-- A parent clip with the bar's rounded geometry clips the shader's OUTPUT (the displacement
             would otherwise pull opaque pixels into the corners, squaring them). GlassClipGeometry.Rect
             is kept in sync with the bar size in code (UpdateGlassClip, via SyncAcrylic / frame upload). -->
        <Canvas x:Name="GlassClipHost"
                Canvas.Left="{Binding BarLeft}"
                Canvas.Top="{Binding BarTop}"
                Width="{Binding BarWidth}"
                Height="{Binding BarHeight}"
                IsHitTestVisible="False">
            <Canvas.Clip>
                <RectangleGeometry x:Name="GlassClipGeometry" RadiusX="24" RadiusY="24" />
            </Canvas.Clip>
            <!-- Two nested Borders = a separable 2-pass Gaussian: the inner one refracts + blurs
                 horizontally, the outer blurs the result vertically (effects compose bottom-up). -->
            <Border x:Name="GlassRefractOuter"
                    Width="{Binding BarWidth}"
                    Height="{Binding BarHeight}"
                    CornerRadius="24"
                    Visibility="Collapsed">
                <Border x:Name="GlassRefract"
                        Width="{Binding BarWidth}"
                        Height="{Binding BarHeight}"
                        CornerRadius="24">
                    <Border.Background>
                        <!-- The capture spans the max magnified bar extent; the Viewbox (absolute px,
                             set in UpdateGlassClip) crops the live bar's slice out of it. -->
                        <ImageBrush x:Name="GlassBackdropBrush" Stretch="Fill" ViewboxUnits="Absolute" />
                    </Border.Background>
                </Border>
            </Border>
        </Canvas>

        <!-- Translucent "glass" dock bar (rounded, widens with magnification). In Liquid Glass mode this
             is the Simple translucent overlay + border drawn on top of the refraction beneath it. -->
        <Border x:Name="DockBackground"
                Canvas.Left="{Binding BarLeft}"
                Canvas.Top="{Binding BarTop}"
                Width="{Binding BarWidth}"
                Height="{Binding BarHeight}"
                CornerRadius="24"
                BorderBrush="{DynamicResource BarBorderBrush}"
                BorderThickness="1"
                Background="{DynamicResource BarBackgroundBrush}">
            <Border.Effect>
                <!-- box-shadow: 0 10px 30px rgba(0,0,0,0.15) light / 0.4 dark (Opacity set in ApplyTheme) -->
                <DropShadowEffect x:Name="BarShadow" BlurRadius="30" ShadowDepth="10" Direction="270" Opacity="0.15" Color="#000000" />
            </Border.Effect>
        </Border>

        <!-- Liquid Glass: a curved-rim highlight + top specular sheen layered over the acrylic. The
             middle stays clear so the blur shows through ("flat center, glassy edge"). Click-through;
             shown only in LiquidGlass mode (toggled in ApplyGlassEffect). -->
        <Border x:Name="GlassRim"
                Canvas.Left="{Binding BarLeft}"
                Canvas.Top="{Binding BarTop}"
                Width="{Binding BarWidth}"
                Height="{Binding BarHeight}"
                CornerRadius="24"
                BorderThickness="1.5"
                IsHitTestVisible="False"
                Visibility="Collapsed">
            <Border.BorderBrush>
                <!-- Bright rim light at the top edge, fading down — reads as a curved glass edge. -->
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Offset="0"   Color="#C8FFFFFF" />
                    <GradientStop Offset="0.5" Color="#28FFFFFF" />
                    <GradientStop Offset="1"   Color="#55FFFFFF" />
                </LinearGradientBrush>
            </Border.BorderBrush>
            <Border.Background>
                <!-- Top specular sheen → clear middle (acrylic shows through) → faint base glow. -->
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Offset="0"    Color="#3CFFFFFF" />
                    <GradientStop Offset="0.32" Color="#0AFFFFFF" />
                    <GradientStop Offset="0.7"  Color="#00FFFFFF" />
                    <GradientStop Offset="1"    Color="#16FFFFFF" />
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!-- A slow diagonal highlight that drifts across the glass (the "liquid" motion). Its bright
             band is the middle gradient stop, swept by an animation started/stopped in ApplyGlassEffect.
             Border.Background is clipped to the rounded corners automatically. -->
        <Border x:Name="GlassShimmer"
                Canvas.Left="{Binding BarLeft}"
                Canvas.Top="{Binding BarTop}"
                Width="{Binding BarWidth}"
                Height="{Binding BarHeight}"
                CornerRadius="24"
                IsHitTestVisible="False"
                Visibility="Collapsed">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Offset="0" Color="#00FFFFFF" />
                    <GradientStop x:Name="ShimmerStop" Offset="0" Color="#22FFFFFF" />
                    <GradientStop Offset="1" Color="#00FFFFFF" />
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <ItemsControl ItemsSource="{Binding Items}"
                      ItemTemplate="{StaticResource DockItemTemplate}"
                      ItemContainerStyle="{StaticResource DockItemContainerStyle}"
                      Width="{Binding WindowWidth}"
                      Height="{Binding WindowHeight}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Canvas />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>

        <!-- Drag ghost: a top-level popup so a dragged icon can roam the whole screen, outside
             the dock window's bounds. Position (HorizontalOffset/VerticalOffset relative to
             RootCanvas) is driven from code as the cursor moves. Fixed geometry keeps the icon
             centered on the cursor: width 160, a 42px reserved area above for the "Remove" tag,
             then the 60px icon — so its center is always (80, 72) from the popup's top-left. -->
        <Popup x:Name="DragGhost"
               Placement="Relative"
               PlacementTarget="{Binding ElementName=RootCanvas}"
               AllowsTransparency="True"
               StaysOpen="True"
               PopupAnimation="None"
               IsHitTestVisible="False"
               IsOpen="False">
            <StackPanel x:Name="GhostRoot" Width="160">
                <!-- "Remove" tag (themed balloon + downward arrow). Reserves its 42px row even when
                     hidden, so arming it never shifts the icon. Opacity is faded in/out in code. -->
                <Grid Height="42">
                    <StackPanel x:Name="GhostRemoveTag"
                                VerticalAlignment="Bottom"
                                HorizontalAlignment="Center"
                                Opacity="0">
                        <Border CornerRadius="7"
                                Padding="10,4"
                                Background="{DynamicResource LabelBgBrush}"
                                BorderBrush="{DynamicResource LabelBorderBrush}"
                                BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.4" Color="#000000" />
                            </Border.Effect>
                            <TextBlock Text="Remove" Foreground="{DynamicResource LabelTextBrush}" FontSize="12" FontWeight="SemiBold" />
                        </Border>
                        <Path HorizontalAlignment="Center" Margin="0,-1.5,0,0"
                              Fill="{DynamicResource LabelBgBrush}" Data="M 0,0 L 14,0 L 7,7 Z" />
                    </StackPanel>
                </Grid>

                <Image x:Name="GhostIcon"
                       Width="60" Height="60"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="HighQuality">
                    <Image.Effect>
                        <DropShadowEffect BlurRadius="14" ShadowDepth="4" Opacity="0.5" Color="#000000" />
                    </Image.Effect>
                </Image>
            </StackPanel>
        </Popup>

        <!-- Folder fan-out ("View content as: Fan"): a popup (its own hwnd, so the dock's idle
             window-region clip can't cut it off) holding the fanned item rows, built and animated
             in code (OpenFolderFan). Light-dismiss is MANUAL (StaysOpen=True): a subtree mouse
             capture routes any outside click here so the fan can retract (fan back in) before the
             popup actually closes — StaysOpen=False would snap it shut with no animation. -->
        <Popup x:Name="FanPopup"
               Placement="Relative"
               PlacementTarget="{Binding ElementName=RootCanvas}"
               AllowsTransparency="True"
               StaysOpen="True"
               PopupAnimation="None"
               Closed="OnFanClosed"
               IsOpen="False">
            <Canvas x:Name="FanCanvas"
                    Mouse.PreviewMouseDownOutsideCapturedElement="OnFanOutsideClick"
                    LostMouseCapture="OnFanLostCapture"
                    PreviewMouseUp="OnFanPreviewMouseUp" />
        </Popup>

    </Canvas>
</Window>
