<Window x:Class="Dockable.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:Dockable.Localization"
        xmlns:a11y="clr-namespace:Dockable.Accessibility"
        Title="{loc:Loc Window_DockPreferences}"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Width="740"
        Height="685"
        MinWidth="620"
        MinHeight="440"
        Background="#EDEDED"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Ideal"
        FontFamily="Segoe UI"
        Foreground="#1D1D1F">

    <Window.Resources>
        <!-- macOS-style toggle switch -->
        <Style x:Key="MacSwitch" TargetType="ToggleButton">
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Track" CornerRadius="11">
                            <Border.Background>
                                <!-- Explicit (mutable) brush so its Color can be animated. -->
                                <SolidColorBrush x:Name="TrackBrush" Color="#E9E9EA" />
                            </Border.Background>
                            <!-- The knob rests at the left and slides right (via TranslateTransform) when on. -->
                            <Ellipse x:Name="Knob" Width="18" Height="18" Fill="White"
                                     HorizontalAlignment="Left" Margin="2,0,0,0">
                                <Ellipse.RenderTransform>
                                    <TranslateTransform x:Name="KnobShift" X="0" />
                                </Ellipse.RenderTransform>
                                <Ellipse.Effect>
                                    <DropShadowEffect BlurRadius="3" ShadowDepth="0.5" Opacity="0.35" Color="#000000" />
                                </Ellipse.Effect>
                            </Ellipse>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <!-- Travel = track(38) - knob(18) - margins(2+2) = 16. -->
                                            <DoubleAnimation Storyboard.TargetName="KnobShift" Storyboard.TargetProperty="X"
                                                             To="16" Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <ColorAnimation Storyboard.TargetName="TrackBrush" Storyboard.TargetProperty="Color"
                                                            To="#0A84FF" Duration="0:0:0.18" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="KnobShift" Storyboard.TargetProperty="X"
                                                             To="0" Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <ColorAnimation Storyboard.TargetName="TrackBrush" Storyboard.TargetProperty="Color"
                                                            To="#E9E9EA" Duration="0:0:0.18" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- macOS-style slider: thin gray track + round white thumb. Tick marks render only when
             TickPlacement is set (e.g. the Effect Speed slider's 5 positions). -->
        <Style x:Key="MacSlider" TargetType="Slider">
            <Setter Property="MinHeight" Value="22" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsMoveToPointEnabled" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <!-- Full width so the first/last ticks sit at the very ends of the slider. -->
                            <TickBar x:Name="TopTick" Grid.Row="0" Placement="Top" Height="4" Fill="#B6B6BB"
                                     SnapsToDevicePixels="True" Visibility="Collapsed" Margin="0,0,0,3"
                                     Minimum="{TemplateBinding Minimum}" Maximum="{TemplateBinding Maximum}"
                                     TickFrequency="{TemplateBinding TickFrequency}" />
                            <Grid Grid.Row="1" VerticalAlignment="Center">
                                <Border Height="4" CornerRadius="2" Background="#D6D6DA" VerticalAlignment="Center" />
                                <Track x:Name="PART_Track">
                                    <!-- Filled (left) side of the track: the same active blue as the
                                         switches. The transparent right side keeps track clicks and
                                         move-to-point working. -->
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="Slider.DecreaseLarge" Focusable="False">
                                            <RepeatButton.Template>
                                                <ControlTemplate TargetType="RepeatButton">
                                                    <Grid Background="Transparent" Height="22">
                                                        <Border Height="4" CornerRadius="2,0,0,2" Background="#0A84FF" VerticalAlignment="Center" />
                                                    </Grid>
                                                </ControlTemplate>
                                            </RepeatButton.Template>
                                        </RepeatButton>
                                    </Track.DecreaseRepeatButton>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="Slider.IncreaseLarge" Focusable="False">
                                            <RepeatButton.Template>
                                                <ControlTemplate TargetType="RepeatButton">
                                                    <Grid Background="Transparent" Height="22" />
                                                </ControlTemplate>
                                            </RepeatButton.Template>
                                        </RepeatButton>
                                    </Track.IncreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb>
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Ellipse Width="20" Height="20" Fill="White"
                                                             Stroke="#22000000" StrokeThickness="0.5">
                                                        <Ellipse.Effect>
                                                            <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.25" Color="#000000" />
                                                        </Ellipse.Effect>
                                                    </Ellipse>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </Track.Thumb>
                                </Track>
                            </Grid>
                            <TickBar x:Name="BottomTick" Grid.Row="2" Placement="Bottom" Height="4" Fill="#B6B6BB"
                                     SnapsToDevicePixels="True" Visibility="Collapsed" Margin="0,3,0,0"
                                     Minimum="{TemplateBinding Minimum}" Maximum="{TemplateBinding Maximum}"
                                     TickFrequency="{TemplateBinding TickFrequency}" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="TickPlacement" Value="TopLeft">
                                <Setter TargetName="TopTick" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="TickPlacement" Value="BottomRight">
                                <Setter TargetName="BottomTick" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="TickPlacement" Value="Both">
                                <Setter TargetName="TopTick" Property="Visibility" Value="Visible" />
                                <Setter TargetName="BottomTick" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- macOS-style pop-up button (ComboBox) -->
        <Style x:Key="MacPopupItem" TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="4"
                                Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0A84FF" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MacPopup" TargetType="ComboBox">
            <Setter Property="Height" Value="26" />
            <Setter Property="MinWidth" Value="130" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#1D1D1F" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource MacPopupItem}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="White" CornerRadius="6"
                                                BorderBrush="#22000000" BorderThickness="1">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="2" ShadowDepth="0.5" Opacity="0.12" Color="#000000" />
                                            </Border.Effect>
                                            <Path HorizontalAlignment="Right" VerticalAlignment="Center"
                                                  Margin="0,0,9,0" Stroke="#7A7A7E" StrokeThickness="1.3"
                                                  Data="M 0,3.5 L 3.5,0.5 L 7,3.5  M 0,7.5 L 3.5,10.5 L 7,7.5" />
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="11,0,26,0" VerticalAlignment="Center"
                                              HorizontalAlignment="Left" IsHitTestVisible="False" />
                            <Popup IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom" AllowsTransparency="True" PopupAnimation="Fade"
                                   Focusable="False">
                                <Border Background="White" CornerRadius="6" Margin="0,4,0,4"
                                        BorderBrush="#22000000" BorderThickness="1"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.22" Color="#000000" />
                                    </Border.Effect>
                                    <ItemsPresenter Margin="3" />
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Shared text styles -->
        <Style x:Key="RowLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#1D1D1F" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="Caption" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#8A8A8E" />
        </Style>
        <Style x:Key="GroupLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#1D1D1F" />
        </Style>

        <!-- Section header at the top of a content page -->
        <Style x:Key="PageHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#1D1D1F" />
            <Setter Property="Margin" Value="2,0,0,8" />
        </Style>

        <!-- Sidebar navigation row (macOS System Settings look): icon square + label -->
        <Style x:Key="NavRow" TargetType="Border">
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Margin" Value="0,0,0,2" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style x:Key="NavIcon" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- "Built with" clickable technology chip (About page): a light pill with a colored badge + name -->
        <Style x:Key="TechChip" TargetType="Border">
            <Setter Property="Background" Value="#F2F2F4" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="ToolTip" Value="{loc:Loc About_OpensInBrowser}" />
        </Style>
        <!-- "Opens in your browser" glyph appended to every external link on the About page -->
        <Style x:Key="LinkGlyph" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="9" />
            <Setter Property="Foreground" Value="#6E6E73" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="5,1,0,0" />
            <Setter Property="Text" Value="&#xE8A7;" />
        </Style>
        <Style x:Key="TechBadge" TargetType="Border">
            <Setter Property="Width" Value="20" />
            <Setter Property="Height" Value="20" />
            <Setter Property="CornerRadius" Value="5" />
        </Style>
        <Style x:Key="TechBadgeText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="9" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="TechName" TargetType="TextBlock">
            <Setter Property="Margin" Value="7,0,0,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#1D1D1F" />
        </Style>
        <!-- Feature bullet in the Highlights card -->
        <Style x:Key="BulletIcon" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#0A84FF" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="Margin" Value="0,2,10,0" />
        </Style>
        <Style x:Key="BulletText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#1D1D1F" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="LineHeight" Value="18" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#E4E4E4" BorderBrush="#D0D0D0" BorderThickness="0,0,1,0">
            <StackPanel Margin="10,16,10,10">
                <!-- Search: filters the settings index (names + tags); results replace the nav list. -->
                <Border Background="White" CornerRadius="7" BorderBrush="#D0D0D0" BorderThickness="1"
                        Padding="8,0" Margin="0,0,0,10">
                    <Grid Height="28">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#xE721;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   FontSize="12" Foreground="#8E8E93" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <Grid Grid.Column="1">
                            <TextBox x:Name="SearchBox" BorderThickness="0" Background="Transparent"
                                     AutomationProperties.Name="{loc:Loc Search_Placeholder}"
                                     VerticalAlignment="Center" FontSize="13" Foreground="#1D1D1F"
                                     TextChanged="SearchBox_TextChanged" />
                            <TextBlock x:Name="SearchHint" Text="{loc:Loc Search_Placeholder}" FontSize="13"
                                       Foreground="#9A9AA0" VerticalAlignment="Center" IsHitTestVisible="False" />
                        </Grid>
                    </Grid>
                </Border>

                <!-- Search results (rows built in code); shown instead of the nav while searching. -->
                <StackPanel x:Name="SearchResults" Visibility="Collapsed" />

                <StackPanel x:Name="NavList">
                <!-- General -->
                <a11y:InvokableCell x:Name="NavGeneral" Style="{StaticResource NavRow}" Tag="General"
                        AutomationProperties.Name="{loc:Loc Nav_General}"
                        MouseLeftButtonUp="NavItem_Click">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="24" Height="24" CornerRadius="6" Background="#8E8E93">
                            <TextBlock Text="&#xE713;" Style="{StaticResource NavIcon}" />
                        </Border>
                        <TextBlock x:Name="NavGeneralLabel" Text="{loc:Loc Nav_General}" Margin="10,0,0,0"
                                   VerticalAlignment="Center" FontSize="13" Foreground="#1D1D1F" />
                    </StackPanel>
                </a11y:InvokableCell>

                <!-- Dock & Menu Bar -->
                <a11y:InvokableCell x:Name="NavDockMenuBar" Style="{StaticResource NavRow}" Tag="DockMenuBar"
                        AutomationProperties.Name="{loc:Loc Nav_DockMenuBar}"
                        MouseLeftButtonUp="NavItem_Click">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="24" Height="24" CornerRadius="6" Background="#0A84FF">
                            <TextBlock Text="&#xE8A9;" Style="{StaticResource NavIcon}" />
                        </Border>
                        <TextBlock x:Name="NavDockMenuBarLabel" Text="{loc:Loc Nav_DockMenuBar}" Margin="10,0,0,0"
                                   VerticalAlignment="Center" FontSize="13" Foreground="#1D1D1F" />
                    </StackPanel>
                </a11y:InvokableCell>

                <!-- Liquid Glass -->
                <a11y:InvokableCell x:Name="NavLiquidGlass" Style="{StaticResource NavRow}" Tag="LiquidGlass"
                        AutomationProperties.Name="{loc:Loc Nav_LiquidGlass}"
                        MouseLeftButtonUp="NavItem_Click">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="24" Height="24" CornerRadius="6">
                            <Border.Background>
                                <!-- Liquid-glass sheen: pink core → red → blue → yellow rim, offset
                                     off-center so it reads like light through glass. -->
                                <RadialGradientBrush GradientOrigin="0.3,0.25" Center="0.5,0.5" RadiusX="0.95" RadiusY="0.95">
                                    <GradientStop Color="#FF6FB1" Offset="0" />
                                    <GradientStop Color="#FF3B30" Offset="0.35" />
                                    <GradientStop Color="#0A84FF" Offset="0.72" />
                                    <GradientStop Color="#FFD60A" Offset="1" />
                                </RadialGradientBrush>
                            </Border.Background>
                            <TextBlock Text="&#xE790;" Style="{StaticResource NavIcon}" />
                        </Border>
                        <TextBlock x:Name="NavLiquidGlassLabel" Text="{loc:Loc Nav_LiquidGlass}" Margin="10,0,0,0"
                                   VerticalAlignment="Center" FontSize="13" Foreground="#1D1D1F" />
                    </StackPanel>
                </a11y:InvokableCell>

                <!-- About -->
                <a11y:InvokableCell x:Name="NavAbout" Style="{StaticResource NavRow}" Tag="About"
                        AutomationProperties.Name="{loc:Loc Nav_About}"
                        MouseLeftButtonUp="NavItem_Click">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="24" Height="24" CornerRadius="6" Background="#1D1D1F">
                            <TextBlock Text="&#xE946;" Style="{StaticResource NavIcon}" />
                        </Border>
                        <TextBlock x:Name="NavAboutLabel" Text="{loc:Loc Nav_About}" Margin="10,0,0,0"
                                   VerticalAlignment="Center" FontSize="13" Foreground="#1D1D1F" />
                    </StackPanel>
                </a11y:InvokableCell>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Content pages (only the selected one is visible) -->
        <Grid Grid.Column="1">

            <!-- ============ General ============ -->
            <ScrollViewer x:Name="PageGeneral" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled" Focusable="False"
                          PanningMode="VerticalOnly">
                <StackPanel Margin="20">
                    <!-- System section (language + login) -->
                    <TextBlock Text="{loc:Loc Section_System}" Style="{StaticResource PageHeader}" />
                    <Border Background="White" CornerRadius="10" Margin="0,0,0,18">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.12" Color="#000000" />
                        </Border.Effect>
                        <StackPanel Margin="16,0,16,8">
                            <!-- Language: native names; selection maps to a culture code in code-behind. -->
                            <Grid Height="44">
                                <TextBlock Text="{loc:Loc Row_Language}" Style="{StaticResource RowLabel}" HorizontalAlignment="Left" />
                                <ComboBox x:Name="LanguageCombo" Style="{StaticResource MacPopup}" HorizontalAlignment="Right"
                                          AutomationProperties.Name="{loc:Loc Row_Language}"
                                          VerticalAlignment="Center" SelectionChanged="LanguageCombo_SelectionChanged" />
                            </Grid>

                            <Border Height="1" Background="#E3E3E3" />

                            <Grid Height="44">
                                <TextBlock Text="{loc:Loc Row_Performance}" Style="{StaticResource RowLabel}" HorizontalAlignment="Left" />
                                <ComboBox x:Name="PerformanceCombo" Style="{StaticResource MacPopup}" HorizontalAlignment="Right"
                                          AutomationProperties.Name="{loc:Loc Row_Performance}"
                                          VerticalAlignment="Center" SelectionChanged="PerformanceCombo_SelectionChanged">
                                    <ComboBoxItem Content="{loc:Loc Performance_Auto}" />
                                    <ComboBoxItem Content="{loc:Loc Performance_Quality}" />
                                    <ComboBoxItem Content="{loc:Loc Performance_Performance}" />
                                </ComboBox>
                            </Grid>

                            <Border Height="1" Background="#E3E3E3" Margin="0,0,0,0" />
                            <Grid Height="44">
                                <TextBlock Text="{loc:Loc Row_OpenAtLogin}" Style="{StaticResource RowLabel}" HorizontalAlignment="Left" />
                                <ToggleButton x:Name="OpenAtLoginSwitch" Style="{StaticResource MacSwitch}" HorizontalAlignment="Right"
                                              AutomationProperties.Name="{loc:Loc Row_OpenAtLogin}"
                                              VerticalAlignment="Center" Click="OpenAtLoginSwitch_Click" />
                            </Grid>
                            <!-- Link to the Windows "Startup Apps" settings page (opens in a new window). -->
                            <a11y:InvokableRow Orientation="Horizontal" HorizontalAlignment="Right" Cursor="Hand"
                                        AutomationProperties.Name="{loc:Loc Link_StartupApps}"
                                        Background="Transparent" MouseLeftButtonUp="StartupApps_Click" Margin="0,0,0,4">
                                <TextBlock Text="{loc:Loc Link_StartupApps}" Foreground="#0A84FF" FontSize="12"
                                           TextDecorations="Underline" VerticalAlignment="Center" />
                                <TextBlock Text="&#x2197;" Foreground="#0A84FF" FontSize="12"
                                           Margin="3,0,0,0" VerticalAlignment="Center" />
                            </a11y:InvokableRow>
                        </StackPanel>
                    </Border>

                    <!-- Appearance section (mimics macOS Settings > Appearance) -->
                    <TextBlock Text="{loc:Loc Section_Appearance}" Style="{StaticResource PageHeader}" />
                    <Border Background="White" CornerRadius="10" Margin="0,0,0,18">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.12" Color="#000000" />
                        </Border.Effect>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="16,16">
                            <!-- Light -->
                            <StackPanel Margin="12,0">
                                <Border x:Name="LightSel" CornerRadius="11" BorderThickness="2" BorderBrush="Transparent"
                                        Padding="3" Cursor="Hand" Tag="Light" MouseLeftButtonUp="AppearanceTile_Click">
                                    <Border CornerRadius="8" ClipToBounds="True" Width="76" Height="48">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#5B8DEF" Offset="0" />
                                                <GradientStop Color="#9FC0FF" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <!-- Mini dock (light styling) -->
                                        <Border VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,5"
                                                Width="44" Height="13" CornerRadius="5"
                                                Background="#66FFFFFF" BorderBrush="#33FFFFFF" BorderThickness="1">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Border Width="6" Height="6" CornerRadius="1.5" Background="#5B8DEF" Margin="1.5,0" />
                                                <Border Width="6" Height="6" CornerRadius="1.5" Background="#34C759" Margin="1.5,0" />
                                                <Border Width="6" Height="6" CornerRadius="1.5" Background="#FF9F0A" Margin="1.5,0" />
                                                <Border Width="6" Height="6" CornerRadius="1.5" Background="#FF375F" Margin="1.5,0" />
                                            </StackPanel>
                                        </Border>
                                    </Border>
                                </Border>
                                <RadioButton x:Name="LightRadio" GroupName="Appearance" Content="{loc:Loc Theme_Light}" Tag="Light"
                                             HorizontalAlignment="Center" Margin="0,7,0,0" FontSize="12"
                                             Foreground="#1D1D1F" Checked="AppearanceRadio_Checked" />
                            </StackPanel>

                            <!-- Dark -->
                            <StackPanel Margin="12,0">
                                <Border x:Name="DarkSel" CornerRadius="11" BorderThickness="2" BorderBrush="Transparent"
                                        Padding="3" Cursor="Hand" Tag="Dark" MouseLeftButtonUp="AppearanceTile_Click">
                                    <Border CornerRadius="8" ClipToBounds="True" Width="76" Height="48">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#4B74C4" Offset="0" />
                                                <GradientStop Color="#829DD1" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <!-- Mini dock (dark styling) -->
                                        <Border VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,5"
                                                Width="44" Height="13" CornerRadius="5"
                                                Background="#66242424" BorderBrush="#14FFFFFF" BorderThickness="1">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Border Width="6" Height="6" CornerRadius="1.5" Background="#5B8DEF" Margin="1.5,0" />
                                                <Border Width="6" Height="6" CornerRadius="1.5" Background="#34C759" Margin="1.5,0" />
                                                <Border Width="6" Height="6" CornerRadius="1.5" Background="#FF9F0A" Margin="1.5,0" />
                                                <Border Width="6" Height="6" CornerRadius="1.5" Background="#FF375F" Margin="1.5,0" />
                                            </StackPanel>
                                        </Border>
                                    </Border>
                                </Border>
                                <RadioButton x:Name="DarkRadio" GroupName="Appearance" Content="{loc:Loc Theme_Dark}" Tag="Dark"
                                             HorizontalAlignment="Center" Margin="0,7,0,0" FontSize="12"
                                             Foreground="#1D1D1F" Checked="AppearanceRadio_Checked" />
                            </StackPanel>

                            <!-- Auto (half light / half dark) -->
                            <StackPanel Margin="12,0">
                                <Border x:Name="AutoSel" CornerRadius="11" BorderThickness="2" BorderBrush="Transparent"
                                        Padding="3" Cursor="Hand" Tag="Auto" MouseLeftButtonUp="AppearanceTile_Click">
                                    <Border CornerRadius="8" Width="76" Height="48">
                                        <!-- Round the entire composite (both halves) as one shape, not each box. -->
                                        <Border.Clip>
                                            <RectangleGeometry Rect="0,0,76,48" RadiusX="8" RadiusY="8" />
                                        </Border.Clip>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Rectangle Grid.Column="0">
                                                <Rectangle.Fill>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#5B8DEF" Offset="0" />
                                                        <GradientStop Color="#9FC0FF" Offset="1" />
                                                    </LinearGradientBrush>
                                                </Rectangle.Fill>
                                            </Rectangle>
                                            <Rectangle Grid.Column="1">
                                                <Rectangle.Fill>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#4B74C4" Offset="0" />
                                                        <GradientStop Color="#829DD1" Offset="1" />
                                                    </LinearGradientBrush>
                                                </Rectangle.Fill>
                                            </Rectangle>
                                            <!-- Mini dock spanning both halves: left = light styling, right = dark -->
                                            <Border Grid.ColumnSpan="2" VerticalAlignment="Bottom" HorizontalAlignment="Center"
                                                    Margin="0,0,0,5" Width="44" Height="13" CornerRadius="5"
                                                    ClipToBounds="True" BorderThickness="1" BorderBrush="#26FFFFFF">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Rectangle Grid.Column="0" Fill="#66FFFFFF" />
                                                    <Rectangle Grid.Column="1" Fill="#66242424" />
                                                    <StackPanel Grid.ColumnSpan="2" Orientation="Horizontal"
                                                                HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <Border Width="6" Height="6" CornerRadius="1.5" Background="#5B8DEF" Margin="1.5,0" />
                                                        <Border Width="6" Height="6" CornerRadius="1.5" Background="#34C759" Margin="1.5,0" />
                                                        <Border Width="6" Height="6" CornerRadius="1.5" Background="#FF9F0A" Margin="1.5,0" />
                                                        <Border Width="6" Height="6" CornerRadius="1.5" Background="#FF375F" Margin="1.5,0" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Border>
                                <RadioButton x:Name="AutoRadio" GroupName="Appearance" Content="{loc:Loc Theme_Auto}" Tag="Auto"
                                             HorizontalAlignment="Center" Margin="0,7,0,0" FontSize="12"
                                             Foreground="#1D1D1F" Checked="AppearanceRadio_Checked" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Taskbar section -->
                    <TextBlock Text="{loc:Loc Section_Taskbar}" Style="{StaticResource PageHeader}" />
                    <Border Background="White" CornerRadius="10">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.12" Color="#000000" />
                        </Border.Effect>
                        <Grid Height="44" Margin="16,0">
                            <TextBlock Text="{loc:Loc Row_ShowTaskbar}" Style="{StaticResource RowLabel}" HorizontalAlignment="Left" />
                            <ComboBox x:Name="TaskbarCombo" Style="{StaticResource MacPopup}" HorizontalAlignment="Right"
                                      AutomationProperties.Name="{loc:Loc Row_ShowTaskbar}"
                                      VerticalAlignment="Center" SelectionChanged="TaskbarCombo_SelectionChanged">
                                <ComboBoxItem Content="{loc:Loc Taskbar_Always}" />
                                <ComboBoxItem Content="{loc:Loc Taskbar_Auto}" />
                                <ComboBoxItem Content="{loc:Loc Taskbar_Never}" />
                            </ComboBox>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- ============ Dock & Menu Bar ============ -->
            <ScrollViewer x:Name="PageDockMenuBar" Visibility="Collapsed" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled" Focusable="False"
                          PanningMode="VerticalOnly">
                <StackPanel Margin="20">
                    <TextBlock Text="{loc:Loc Section_Dock}" Style="{StaticResource PageHeader}" />

                    <!-- White grouped card -->
                    <Border Background="White" CornerRadius="10">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.12" Color="#000000" />
                        </Border.Effect>

                        <StackPanel>
                            <!-- Group 1: sliders -->
                            <Grid Margin="16,16,16,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Size -->
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{loc:Loc Label_Size}" Style="{StaticResource GroupLabel}" Margin="0,0,0,6" />
                                    <Slider x:Name="SizeSlider" Style="{StaticResource MacSlider}"
                                            AutomationProperties.Name="{loc:Loc Label_Size}"
                                            Minimum="12" Maximum="64" IsSnapToTickEnabled="True" TickFrequency="1"
                                            ValueChanged="SizeSlider_ValueChanged" />
                                    <Grid Margin="0,2,0,0">
                                        <TextBlock Text="{loc:Loc Caption_Small}" Style="{StaticResource Caption}" HorizontalAlignment="Left" />
                                        <TextBlock Text="{loc:Loc Caption_Large}" Style="{StaticResource Caption}" HorizontalAlignment="Right" />
                                    </Grid>
                                </StackPanel>

                                <!-- Magnification -->
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="{loc:Loc Label_Magnification}" Style="{StaticResource GroupLabel}" Margin="0,0,0,6" />
                                    <Slider x:Name="MagnificationSlider" Style="{StaticResource MacSlider}"
                                            AutomationProperties.Name="{loc:Loc Label_Magnification}"
                                            Minimum="0" Maximum="9" IsSnapToTickEnabled="True" TickFrequency="1"
                                            ValueChanged="MagnificationSlider_ValueChanged" />
                                    <Grid Margin="0,2,0,0">
                                        <TextBlock Text="{loc:Loc Caption_Off}" Style="{StaticResource Caption}" HorizontalAlignment="Left" />
                                        <TextBlock Text="{loc:Loc Caption_Small}" Style="{StaticResource Caption}" HorizontalAlignment="Left" Margin="30,0,0,0" />
                                        <TextBlock Text="{loc:Loc Caption_Large}" Style="{StaticResource Caption}" HorizontalAlignment="Right" />
                                    </Grid>
                                </StackPanel>
                            </Grid>

                            <Border Height="1" Background="#E3E3E3" Margin="16,0,0,0" />

                            <!-- Group 2: pop-up rows -->
                            <Grid Height="44" Margin="16,0">
                                <TextBlock Text="{loc:Loc Row_Position}" Style="{StaticResource RowLabel}" HorizontalAlignment="Left" />
                                <ComboBox x:Name="PositionCombo" Style="{StaticResource MacPopup}" HorizontalAlignment="Right"
                                          AutomationProperties.Name="{loc:Loc Row_Position}"
                                          VerticalAlignment="Center" SelectionChanged="PositionCombo_SelectionChanged">
                                    <ComboBoxItem Content="{loc:Loc Position_Bottom}" />
                                    <ComboBoxItem Content="{loc:Loc Position_Left}" />
                                    <ComboBoxItem Content="{loc:Loc Position_Right}" />
                                    <ComboBoxItem Content="{loc:Loc Position_Top}" />
                                </ComboBox>
                            </Grid>

                            <Border Height="1" Background="#E3E3E3" Margin="16,0,0,0" />

                            <Grid Height="44" Margin="16,0">
                                <TextBlock Text="{loc:Loc Row_MinimizeUsing}" Style="{StaticResource RowLabel}" HorizontalAlignment="Left" />
                                <ComboBox x:Name="MinimizeCombo" Style="{StaticResource MacPopup}" HorizontalAlignment="Right"
                                          AutomationProperties.Name="{loc:Loc Row_MinimizeUsing}"
                                          VerticalAlignment="Center" SelectionChanged="MinimizeCombo_SelectionChanged">
                                    <ComboBoxItem Content="{loc:Loc Minimize_Suck}" />
                                    <ComboBoxItem Content="{loc:Loc Minimize_Scale}" />
                                    <ComboBoxItem Content="{loc:Loc Minimize_Genie}" />
                                </ComboBox>
                            </Grid>

                            <Border Height="1" Background="#E3E3E3" Margin="16,0,0,0" />

                            <!-- Effect speed: the slider matches the Magnification slider's width (same *,24,* grid). -->
                            <Grid Margin="16,8,16,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{loc:Loc Label_EffectSpeed}" Style="{StaticResource RowLabel}"
                                           VerticalAlignment="Center" HorizontalAlignment="Left" />
                                <StackPanel Grid.Column="2">
                                    <!-- 5 snap positions: Slow, ·, Default, ·, Fast (ticks shown). -->
                                    <Slider x:Name="EffectSpeedSlider" Style="{StaticResource MacSlider}"
                                            AutomationProperties.Name="{loc:Loc Label_EffectSpeed}"
                                            Minimum="0" Maximum="4" IsSnapToTickEnabled="True" TickFrequency="1"
                                            TickPlacement="BottomRight" ValueChanged="EffectSpeedSlider_ValueChanged" />
                                    <Grid Margin="0,2,0,0">
                                        <TextBlock Text="{loc:Loc Caption_Slow}" Style="{StaticResource Caption}" HorizontalAlignment="Left" />
                                        <TextBlock Text="{loc:Loc Caption_Default}" Style="{StaticResource Caption}" HorizontalAlignment="Center" />
                                        <TextBlock Text="{loc:Loc Caption_Fast}" Style="{StaticResource Caption}" HorizontalAlignment="Right" />
                                    </Grid>
                                </StackPanel>
                            </Grid>

                            <Border Height="1" Background="#E3E3E3" Margin="16,0,0,0" />

                            <!-- Group 3: toggle rows -->
                            <Grid Height="44" Margin="16,0">
                                <TextBlock Text="{loc:Loc Toggle_ShowIndicators}" Style="{StaticResource RowLabel}" HorizontalAlignment="Left" />
                                <ToggleButton x:Name="IndicatorsSwitch" Style="{StaticResource MacSwitch}" HorizontalAlignment="Right"
                                              AutomationProperties.Name="{loc:Loc Toggle_ShowIndicators}"
                                              VerticalAlignment="Center" Click="IndicatorsSwitch_Click" />
                            </Grid>

                            <Border Height="1" Background="#E3E3E3" Margin="16,0,0,0" />

                            <Grid Height="44" Margin="16,0">
                                <TextBlock Text="{loc:Loc Toggle_AnimateOpening}" Style="{StaticResource RowLabel}" HorizontalAlignment="Left" />
                                <ToggleButton x:Name="AnimateOpeningSwitch" Style="{StaticResource MacSwitch}" HorizontalAlignment="Right"
                                              AutomationProperties.Name="{loc:Loc Toggle_AnimateOpening}"
                                              VerticalAlignment="Center" Click="AnimateOpeningSwitch_Click" />
                            </Grid>

                            <Border Height="1" Background="#E3E3E3" Margin="16,0,0,0" />

                            <Grid Height="44" Margin="16,0">
                                <TextBlock Text="{loc:Loc Toggle_MinimizeIntoIcon}" Style="{StaticResource RowLabel}" HorizontalAlignment="Left" />
                                <ToggleButton x:Name="MinimizeIntoIconSwitch" Style="{StaticResource MacSwitch}" HorizontalAlignment="Right"
                                              AutomationProperties.Name="{loc:Loc Toggle_MinimizeIntoIcon}"
                                              VerticalAlignment="Center" Click="MinimizeIntoIconSwitch_Click" />
                            </Grid>

                            <Border Height="1" Background="#E3E3E3" Margin="16,0,0,0" />

                            <Grid Height="44" Margin="16,0">
                                <TextBlock Text="{loc:Loc Toggle_AutoHideDock}" Style="{StaticResource RowLabel}" HorizontalAlignment="Left" />
                                <ToggleButton x:Name="AutoHideDockSwitch" Style="{StaticResource MacSwitch}" HorizontalAlignment="Right"
                                              AutomationProperties.Name="{loc:Loc Toggle_AutoHideDock}"
                                              VerticalAlignment="Center" Click="AutoHideDockSwitch_Click" />
                            </Grid>

                            <Border Height="1" Background="#E3E3E3" Margin="16,0,0,0" />

                            <Grid Height="44" Margin="16,0">
                                <TextBlock Text="{loc:Loc Toggle_HideOnFullscreen}" Style="{StaticResource RowLabel}" HorizontalAlignment="Left" />
                                <ToggleButton x:Name="HideOnFullscreenSwitch" Style="{StaticResource MacSwitch}" HorizontalAlignment="Right"
                                              AutomationProperties.Name="{loc:Loc Toggle_HideOnFullscreen}"
                                              VerticalAlignment="Center" Click="HideOnFullscreenSwitch_Click" />
                            </Grid>

                        </StackPanel>
                    </Border>

                    <!-- Menu Bar section -->
                    <TextBlock Text="{loc:Loc Section_MenuBar}" Style="{StaticResource PageHeader}" Margin="2,18,0,8" />
                    <Border Background="White" CornerRadius="10">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.12" Color="#000000" />
                        </Border.Effect>
                        <Grid Height="44" Margin="16,0">
                            <TextBlock Text="{loc:Loc Toggle_ShowMenuBar}" Style="{StaticResource RowLabel}" HorizontalAlignment="Left" />
                            <ToggleButton x:Name="ShowMenuBarSwitch" Style="{StaticResource MacSwitch}" HorizontalAlignment="Right"
                                          AutomationProperties.Name="{loc:Loc Toggle_ShowMenuBar}"
                                          VerticalAlignment="Center" Click="ShowMenuBarSwitch_Click" />
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- ============ Liquid Glass ============ -->
            <ScrollViewer x:Name="PageLiquidGlass" Visibility="Collapsed" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled" Focusable="False"
                          PanningMode="VerticalOnly">
                <StackPanel Margin="20">
                    <TextBlock Text="{loc:Loc Section_LiquidGlass}" Style="{StaticResource PageHeader}" />

                    <Border Background="White" CornerRadius="10">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.12" Color="#000000" />
                        </Border.Effect>
                        <StackPanel>
                            <!-- Glass Effect picker (moved here from the Dock section) -->
                            <Grid Height="44" Margin="16,0">
                                <TextBlock Text="{loc:Loc Row_GlassEffect}" Style="{StaticResource RowLabel}" HorizontalAlignment="Left" />
                                <ComboBox x:Name="GlassEffectCombo" Style="{StaticResource MacPopup}" HorizontalAlignment="Right"
                                          AutomationProperties.Name="{loc:Loc Row_GlassEffect}"
                                          VerticalAlignment="Center" SelectionChanged="GlassEffectCombo_SelectionChanged">
                                    <ComboBoxItem Content="{loc:Loc Glass_Translucent}" />
                                    <ComboBoxItem Content="{loc:Loc Glass_Acrylic}" />
                                    <ComboBoxItem Content="{loc:Loc Glass_LiquidGlass}" />
                                </ComboBox>
                            </Grid>

                            <!-- Separates the combo from the Advanced link / sliders; hidden (with them)
                                 when the effect isn't Liquid Glass so no bare rule trails the card. -->
                            <Border x:Name="GlassAdvancedDivider" Height="1" Background="#E3E3E3" Margin="16,0,0,0" />

                            <!-- Advanced: one-way reveal of the tuning sliders — shown only while the
                                 effect is Liquid Glass AND the sliders are still collapsed. -->
                            <a11y:InvokableRow x:Name="GlassAdvancedLink" Orientation="Horizontal" HorizontalAlignment="Right"
                                        AutomationProperties.Name="{loc:Loc LiquidGlass_Advanced}"
                                        Cursor="Hand" Background="Transparent" MouseLeftButtonUp="GlassAdvanced_Click"
                                        Margin="16,8,16,10">
                                <TextBlock Text="{loc:Loc LiquidGlass_Advanced}" Foreground="#0A84FF" FontSize="12"
                                           TextDecorations="Underline" VerticalAlignment="Center" />
                                <TextBlock Text="&#xE70D;"
                                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="10"
                                           Foreground="#0A84FF" VerticalAlignment="Center" Margin="5,1,0,0" />
                            </a11y:InvokableRow>

                            <!-- Tuning sliders (behind Advanced; Liquid Glass only). -->
                            <StackPanel x:Name="GlassParamsPanel" Visibility="Collapsed">
                                <!-- Blur -->
                                <Grid Margin="16,10,16,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="24" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{loc:Loc LiquidGlass_BlurRadius}" Style="{StaticResource RowLabel}"
                                               VerticalAlignment="Center" HorizontalAlignment="Left" />
                                    <StackPanel Grid.Column="2">
                                        <Slider x:Name="GlassBlurSlider" Style="{StaticResource MacSlider}"
                                                AutomationProperties.Name="{loc:Loc LiquidGlass_BlurRadius}"
                                                Minimum="0" Maximum="6" ValueChanged="GlassSlider_ValueChanged" />
                                        <Grid Margin="0,2,0,0">
                                            <TextBlock Text="{loc:Loc Caption_Less}" Style="{StaticResource Caption}" HorizontalAlignment="Left" />
                                            <TextBlock Text="{loc:Loc Caption_More}" Style="{StaticResource Caption}" HorizontalAlignment="Right" />
                                        </Grid>
                                    </StackPanel>
                                </Grid>

                                <Border Height="1" Background="#E3E3E3" Margin="16,0,0,0" />

                                <!-- Distortion -->
                                <Grid Margin="16,10,16,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="24" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{loc:Loc LiquidGlass_Distortion}" Style="{StaticResource RowLabel}"
                                               VerticalAlignment="Center" HorizontalAlignment="Left" />
                                    <StackPanel Grid.Column="2">
                                        <Slider x:Name="GlassDistortionSlider" Style="{StaticResource MacSlider}"
                                                AutomationProperties.Name="{loc:Loc LiquidGlass_Distortion}"
                                                Minimum="0" Maximum="80" ValueChanged="GlassSlider_ValueChanged" />
                                        <Grid Margin="0,2,0,0">
                                            <TextBlock Text="{loc:Loc Caption_Less}" Style="{StaticResource Caption}" HorizontalAlignment="Left" />
                                            <TextBlock Text="{loc:Loc Caption_More}" Style="{StaticResource Caption}" HorizontalAlignment="Right" />
                                        </Grid>
                                    </StackPanel>
                                </Grid>

                                <Border Height="1" Background="#E3E3E3" Margin="16,0,0,0" />

                                <!-- Tint opacity -->
                                <Grid Margin="16,10,16,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="24" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{loc:Loc LiquidGlass_Opacity}" Style="{StaticResource RowLabel}"
                                               VerticalAlignment="Center" HorizontalAlignment="Left" />
                                    <StackPanel Grid.Column="2">
                                        <Slider x:Name="GlassTintSlider" Style="{StaticResource MacSlider}"
                                                AutomationProperties.Name="{loc:Loc LiquidGlass_Opacity}"
                                                Minimum="0" Maximum="2" ValueChanged="GlassSlider_ValueChanged" />
                                        <Grid Margin="0,2,0,0">
                                            <TextBlock Text="{loc:Loc Caption_Less}" Style="{StaticResource Caption}" HorizontalAlignment="Left" />
                                            <TextBlock Text="{loc:Loc Caption_More}" Style="{StaticResource Caption}" HorizontalAlignment="Right" />
                                        </Grid>
                                    </StackPanel>
                                </Grid>

                                <Border Height="1" Background="#E3E3E3" Margin="16,0,0,0" />

                                <!-- Saturation -->
                                <Grid Margin="16,10,16,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="24" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{loc:Loc LiquidGlass_Saturation}" Style="{StaticResource RowLabel}"
                                               VerticalAlignment="Center" HorizontalAlignment="Left" />
                                    <StackPanel Grid.Column="2">
                                        <Slider x:Name="GlassSaturationSlider" Style="{StaticResource MacSlider}"
                                                AutomationProperties.Name="{loc:Loc LiquidGlass_Saturation}"
                                                Minimum="1" Maximum="2.5" ValueChanged="GlassSlider_ValueChanged" />
                                        <Grid Margin="0,2,0,0">
                                            <TextBlock Text="{loc:Loc Caption_Less}" Style="{StaticResource Caption}" HorizontalAlignment="Left" />
                                            <TextBlock Text="{loc:Loc Caption_More}" Style="{StaticResource Caption}" HorizontalAlignment="Right" />
                                        </Grid>
                                    </StackPanel>
                                </Grid>

                                <Border Height="1" Background="#E3E3E3" Margin="16,0,0,0" />

                                <!-- Chromatic aberration -->
                                <Grid Margin="16,10,16,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="24" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{loc:Loc LiquidGlass_Aberration}" Style="{StaticResource RowLabel}"
                                               VerticalAlignment="Center" HorizontalAlignment="Left" />
                                    <StackPanel Grid.Column="2">
                                        <Slider x:Name="GlassAberrationSlider" Style="{StaticResource MacSlider}"
                                                AutomationProperties.Name="{loc:Loc LiquidGlass_Aberration}"
                                                Minimum="0" Maximum="2" ValueChanged="GlassSlider_ValueChanged" />
                                        <Grid Margin="0,2,0,0">
                                            <TextBlock Text="{loc:Loc Caption_Less}" Style="{StaticResource Caption}" HorizontalAlignment="Left" />
                                            <TextBlock Text="{loc:Loc Caption_More}" Style="{StaticResource Caption}" HorizontalAlignment="Right" />
                                        </Grid>
                                    </StackPanel>
                                </Grid>

                                <Border Height="1" Background="#E3E3E3" Margin="16,0,0,0" />

                                <!-- Rim highlight (sheen) -->
                                <Grid Margin="16,10,16,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="24" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{loc:Loc LiquidGlass_RimHighlight}" Style="{StaticResource RowLabel}"
                                               VerticalAlignment="Center" HorizontalAlignment="Left" />
                                    <StackPanel Grid.Column="2">
                                        <Slider x:Name="GlassRimSlider" Style="{StaticResource MacSlider}"
                                                AutomationProperties.Name="{loc:Loc LiquidGlass_RimHighlight}"
                                                Minimum="0" Maximum="1" ValueChanged="GlassSlider_ValueChanged" />
                                        <Grid Margin="0,2,0,0">
                                            <TextBlock Text="{loc:Loc Caption_Less}" Style="{StaticResource Caption}" HorizontalAlignment="Left" />
                                            <TextBlock Text="{loc:Loc Caption_More}" Style="{StaticResource Caption}" HorizontalAlignment="Right" />
                                        </Grid>
                                    </StackPanel>
                                </Grid>

                                <Border Height="1" Background="#E3E3E3" Margin="16,0,0,0" />

                                <!-- Reset to defaults -->
                                <a11y:InvokableRow x:Name="GlassResetLink" Orientation="Horizontal" HorizontalAlignment="Right"
                                            AutomationProperties.Name="{loc:Loc LiquidGlass_Reset}"
                                            Cursor="Hand" Background="Transparent" MouseLeftButtonUp="GlassReset_Click"
                                            Margin="16,8,16,10">
                                    <TextBlock Text="{loc:Loc LiquidGlass_Reset}" Foreground="#0A84FF" FontSize="12"
                                               TextDecorations="Underline" VerticalAlignment="Center" />
                                </a11y:InvokableRow>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- ============ About ============ -->
            <ScrollViewer x:Name="PageAbout" Visibility="Collapsed" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled" Focusable="False"
                          PanningMode="VerticalOnly">
                <StackPanel Margin="20">
                    <!-- App icon + name + tagline + version -->
                    <Image x:Name="AboutAppImage" Width="88" Height="88" HorizontalAlignment="Center" Margin="0,4,0,0"
                           AutomationProperties.Name="Dockable" />
                    <TextBlock Text="Dockable" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,10,0,0" />
                    <TextBlock Text="{loc:Loc About_Tagline}" FontSize="13" Foreground="#3A3A3C"
                               HorizontalAlignment="Center" TextAlignment="Center" Margin="0,3,0,0" />
                    <TextBlock x:Name="AboutVersionText" FontSize="12" Foreground="#6E6E73"
                               HorizontalAlignment="Center" Margin="0,3,0,0" />
                    <!-- Official website -->
                    <TextBlock HorizontalAlignment="Center" FontSize="12" Margin="0,6,0,0">
                        <Hyperlink NavigateUri="https://dockable.app"
                                   RequestNavigate="Hyperlink_RequestNavigate"
                                   ToolTip="{loc:Loc About_OpensInBrowser}"><Run Text="dockable.app" /><Run
                                FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="9"
                                Text="&#160;&#xE8A7;" /></Hyperlink>
                    </TextBlock>

                    <!-- Friendly intro -->
                    <Border Background="White" CornerRadius="10" Margin="0,16,0,0" Padding="16,14">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.12" Color="#000000" />
                        </Border.Effect>
                        <TextBlock Text="{loc:Loc About_Intro}" FontSize="13" Foreground="#1D1D1F"
                                   TextWrapping="Wrap" LineHeight="19" />
                    </Border>

                    <!-- Highlights -->
                    <TextBlock Text="{loc:Loc About_Highlights}" Style="{StaticResource PageHeader}" Margin="2,18,0,8" />
                    <Border Background="White" CornerRadius="10" Padding="16,12">
                        <Border.Effect>
