<Window x:Class="Dockable.MenuBarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Dockable.ViewModels"
        xmlns:conv="clr-namespace:Dockable.Converters"
        xmlns:a11y="clr-namespace:Dockable.Accessibility"
        xmlns:loc="clr-namespace:Dockable.Localization"
        Title="Dockable Menu Bar"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        ResizeMode="NoResize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <!-- Theme brushes (light defaults; ApplyTheme() swaps these at runtime for light/dark). -->
        <SolidColorBrush x:Key="BarBackgroundBrush" Color="#80FFFFFF" />
        <SolidColorBrush x:Key="MenuTextBrush" Color="#1D1D1F" />
        <!-- Active/selected item pill: almost-transparent black on Light, white on Dark. -->
        <SolidColorBrush x:Key="MenuHighlightBrush" Color="#17000000" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    </Window.Resources>

    <!-- Full-width flat bar flush to the top edge (no border, no corner radius). Right-click on
         empty bar space shows the same dock-wide menu as the dock's empty space. -->
    <Border Background="{DynamicResource BarBackgroundBrush}"
            MouseRightButtonUp="Bar_RightClick">
        <!-- The bar's left inset lives INSIDE the Windows-logo button (as padding, not a grid
             margin) so its click target spans the bar's full height from the very left edge. -->
        <Grid Margin="0,0,12,0">
            <!-- Leading: Windows logo (opens Start, like the dock's Start tile) + focused window title. -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Stretch">
                <!-- Interactive items sit inside a "pill" Border (fixed 22px height, radius 11 —
                     fully round) that ActivateHighlight/FlashPill paint with MenuHighlightBrush
                     while the item's menu is open. Pill padding is offset by negative margins so
                     the text/glyph positions match the padless layout exactly. -->
                <a11y:InvokableCell x:Name="StartButton"
                        Background="Transparent"
                        Cursor="Hand"
                        Padding="4,0,4,0"
                        ToolTip="{loc:Loc MenuBar_Tip_Menu}"
                        AutomationProperties.Name="{loc:Loc MenuBar_Tip_Menu}"
                        MouseLeftButtonUp="WindowsLogo_Click">
                    <Border x:Name="StartPill"
                            Height="22" CornerRadius="11" Padding="8,0"
                            Background="Transparent"
                            VerticalAlignment="Center">
                        <!-- The app's launcher glyph (same StartGlyphGeometry as the dock's Start
                             tile) tinted to match the menu-bar text instead of the dock's blue. -->
                        <Viewbox Width="15" Height="15" VerticalAlignment="Center">
                            <Path Fill="{DynamicResource MenuTextBrush}"
                                  Data="{StaticResource StartGlyphGeometry}" />
                        </Viewbox>
                    </Border>
                </a11y:InvokableCell>
                <!-- Focused app's display name — click for the window's title-bar (system) menu. -->
                <a11y:InvokableCell x:Name="AppNamePill"
                        Height="22" CornerRadius="11" Padding="8,0" Margin="-8,0,-8,0"
                        Background="Transparent"
                        Cursor="Hand"
                        VerticalAlignment="Center"
                        AutomationProperties.Name="{Binding AppName}"
                        MouseLeftButtonUp="AppName_Click">
                    <TextBlock x:Name="AppNameText"
                               Text="{Binding AppName}"
                               Foreground="{DynamicResource MenuTextBrush}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />
                </a11y:InvokableCell>

                <!-- The focused app's in-window menu ("File", "Edit", …) mirrored as global menus.
                     Win32-menu apps get their real dropdown hosted under the label; UIA-only apps
                     expand their own menu in place. -->
                <ItemsControl ItemsSource="{Binding MenuEntries}"
                              VerticalAlignment="Center"
                              Margin="18,0,0,0"
                              IsTabStop="False">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- 18px label spacing preserved: 8 pill pad + 10 margin − next's −8. -->
                            <a11y:InvokableCell Height="22" CornerRadius="11" Padding="8,0" Margin="-8,0,10,0"
                                    Background="Transparent"
                                    Cursor="Hand"
                                    VerticalAlignment="Center"
                                    AutomationProperties.Name="{Binding Label}"
                                    MouseLeftButtonUp="AppMenu_Click">
                                <TextBlock Text="{Binding Label}"
                                           Foreground="{DynamicResource MenuTextBrush}"
                                           FontSize="13"
                                           VerticalAlignment="Center" />
                            </a11y:InvokableCell>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Trailing: status cluster (quick-settings, keyboard, clock; tray added in Phase C). -->
            <StackPanel x:Name="StatusPanel"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <!-- Trailing items share the pill treatment: 16px item spacing preserved as
                     8 pill pad + 8 margin − the next pill's −8. -->
                <!-- System-tray overflow ("show hidden icons") — opens the OS flyout. -->
                <a11y:InvokableCell Height="22" CornerRadius="11" Padding="8,0" Margin="-8,0,8,0"
                        Background="Transparent" Cursor="Hand" VerticalAlignment="Center"
                        ToolTip="{loc:Loc MenuBar_Tip_HiddenIcons}"
                        AutomationProperties.Name="{loc:Loc MenuBar_Tip_HiddenIcons}"
                        MouseLeftButtonUp="TrayOverflow_Click">
                    <TextBlock x:Name="TrayOverflowButton"
                               Text="&#xE70D;"
                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               Foreground="{DynamicResource MenuTextBrush}"
                               FontSize="12"
                               VerticalAlignment="Center" />
                </a11y:InvokableCell>

                <!-- Quick Settings (network/sound) — opens the OS flyout via Win+A. -->
                <a11y:InvokableCell Height="22" CornerRadius="11" Padding="8,0" Margin="-8,0,8,0"
                        Background="Transparent" Cursor="Hand" VerticalAlignment="Center"
                        ToolTip="{loc:Loc MenuBar_Tip_QuickSettings}"
                        AutomationProperties.Name="{loc:Loc MenuBar_Tip_QuickSettings}"
                        MouseLeftButtonUp="QuickSettings_Click">
                    <StackPanel x:Name="QuickSettingsButton"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Text="&#xE701;"
                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   Foreground="{DynamicResource MenuTextBrush}"
                                   FontSize="14"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="&#xE767;"
                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   Foreground="{DynamicResource MenuTextBrush}"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   Margin="6,0,0,0" />
                    </StackPanel>
                </a11y:InvokableCell>

                <!-- Battery: level glyph + percentage. Hidden on machines with no battery (desktops).
                     Click opens the OS Power & battery settings. -->
                <a11y:InvokableCell Height="22" CornerRadius="11" Padding="8,0" Margin="-8,0,8,0"
                        Background="Transparent" Cursor="Hand" VerticalAlignment="Center"
                        ToolTip="{loc:Loc MenuBar_Tip_Battery}"
                        AutomationProperties.Name="{loc:Loc MenuBar_Tip_Battery}"
                        Visibility="{Binding HasBattery, Converter={StaticResource BoolToVisibility}}"
                        MouseLeftButtonUp="Battery_Click">
                    <StackPanel x:Name="BatteryButton"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Text="{Binding BatteryGlyph}"
                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   Foreground="{DynamicResource MenuTextBrush}"
                                   FontSize="16"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding BatteryLabel}"
                                   Foreground="{DynamicResource MenuTextBrush}"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Margin="4,0,0,0" />
                    </StackPanel>
                </a11y:InvokableCell>

                <!-- Notifications / calendar — opens the OS flyout via Win+N. (Live tray-icon
                     replication isn't viable on Windows 11 25H2 — see the spike notes — so this is the
                     reliable, update-proof stand-in for tray access.) -->
                <a11y:InvokableCell Height="22" CornerRadius="11" Padding="8,0" Margin="-8,0,8,0"
                        Background="Transparent" Cursor="Hand" VerticalAlignment="Center"
                        ToolTip="{loc:Loc MenuBar_Tip_Notifications}"
                        AutomationProperties.Name="{loc:Loc MenuBar_Tip_Notifications}"
                        MouseLeftButtonUp="Notifications_Click">
                    <TextBlock x:Name="NotificationsButton"
                               Text="&#xE7E7;"
                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               Foreground="{DynamicResource MenuTextBrush}"
                               FontSize="14"
                               VerticalAlignment="Center" />
                </a11y:InvokableCell>

                <!-- Keyboard layout — click to switch the active app's input language. -->
                <a11y:InvokableCell Height="22" CornerRadius="11" Padding="8,0" Margin="-8,0,8,0"
                        Background="Transparent" Cursor="Hand" VerticalAlignment="Center"
                        ToolTip="{loc:Loc MenuBar_Tip_Keyboard}"
                        AutomationProperties.Name="{loc:Loc MenuBar_Tip_Keyboard}"
                        MouseLeftButtonUp="Keyboard_Click">
                    <TextBlock x:Name="KeyboardText"
                               Text="{Binding KeyboardLabel}"
                               Foreground="{DynamicResource MenuTextBrush}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </a11y:InvokableCell>

                <!-- Clock — click to open the Windows "Date & time" settings. -->
                <a11y:InvokableCell Height="22" CornerRadius="11" Padding="8,0" Margin="-8,0,-8,0"
                        Background="Transparent" Cursor="Hand" VerticalAlignment="Center"
                        ToolTip="{loc:Loc MenuBar_Tip_Clock}"
                        AutomationProperties.Name="{loc:Loc MenuBar_Tip_Clock}"
                        MouseLeftButtonUp="Clock_Click">
                    <TextBlock x:Name="ClockText"
                               Text="{Binding TimeText}"
                               Foreground="{DynamicResource MenuTextBrush}"
                               FontSize="12"
                               VerticalAlignment="Center" />
                </a11y:InvokableCell>
            </StackPanel>
        </Grid>
    </Border>
</Window>
