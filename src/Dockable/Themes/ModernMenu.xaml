<!-- Windows 11-style context menus, applied app-wide via implicit styles (every menu in Dockable
     is a code-built WPF ContextMenu, so this dictionary restyles them all: dock item menus, the
     empty-space menu, folder/file menus, the List view, the tray menu, and the menu bar's menus).
     Light defaults below; DockWindow.ApplyTheme swaps the brushes at Application scope for Dark.
     Real acrylic blur isn't possible on WPF popups — the near-opaque tint approximates it. -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="PopupMenuBackgroundBrush" Color="#F5F9F9F9" />
    <SolidColorBrush x:Key="PopupMenuBorderBrush" Color="#1F000000" />
    <SolidColorBrush x:Key="PopupMenuForegroundBrush" Color="#E4000000" />
    <SolidColorBrush x:Key="PopupMenuDisabledBrush" Color="#72000000" />
    <SolidColorBrush x:Key="PopupMenuHoverBrush" Color="#0F000000" />
    <SolidColorBrush x:Key="PopupMenuSeparatorBrush" Color="#1A000000" />

    <!-- Rounded, padded, shadowed menu surface. The outer Margin leaves room for the drop shadow
         inside the (transparent) popup window; scroll arrows kick in for over-tall menus (the
         folder List view). -->
    <Style TargetType="{x:Type ContextMenu}">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Foreground" Value="{DynamicResource PopupMenuForegroundBrush}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="MinWidth" Value="190" />
        <Setter Property="HasDropShadow" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ContextMenu}">
                    <Border Margin="10"
                            Background="{DynamicResource PopupMenuBackgroundBrush}"
                            BorderBrush="{DynamicResource PopupMenuBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="4">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="18" ShadowDepth="6" Direction="270" Opacity="0.30" Color="#000000" />
                        </Border.Effect>
                        <ScrollViewer Style="{DynamicResource {ComponentResourceKey ResourceId=MenuScrollViewer, TypeInTargetAssembly={x:Type FrameworkElement}}}">
                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle"
                                            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                        </ScrollViewer>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Separators inside menus (keyed so MenuItem containers pick it up automatically). -->
    <Style x:Key="{x:Static MenuItem.SeparatorStyleKey}" TargetType="{x:Type Separator}">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Separator}">
                    <Rectangle Height="1" Margin="10,4" Fill="{DynamicResource PopupMenuSeparatorBrush}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- One template covers both roles a ContextMenu produces (SubmenuItem / SubmenuHeader): the
         chevron + submenu popup only light up for headers. The leading column holds the check
         glyph, or the Icon when one is set (the folder List view's file icons). -->
    <Style TargetType="{x:Type MenuItem}">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Foreground" Value="{DynamicResource PopupMenuForegroundBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type MenuItem}">
                    <Border x:Name="Bg" CornerRadius="5" Background="Transparent" Margin="0,1" MinHeight="30">
                        <Grid VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="22" />
                            </Grid.ColumnDefinitions>

                            <TextBlock x:Name="CheckGlyph"
                                       Grid.Column="0"
                                       Text="&#xE73E;"
                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       FontSize="11"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{TemplateBinding Foreground}"
                                       Visibility="Hidden" />
                            <ContentPresenter x:Name="IconHost"
                                              Grid.Column="0"
                                              ContentSource="Icon"
                                              Width="18" Height="18"
                                              HorizontalAlignment="Center" VerticalAlignment="Center" />

                            <ContentPresenter Grid.Column="1"
                                              ContentSource="Header"
                                              RecognizesAccessKey="True"
                                              VerticalAlignment="Center"
                                              Margin="0,5,8,5" />

                            <TextBlock x:Name="Gesture"
                                       Grid.Column="2"
                                       Text="{TemplateBinding InputGestureText}"
                                       Foreground="{DynamicResource PopupMenuDisabledBrush}"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       Margin="14,0,4,0" />

                            <TextBlock x:Name="Chevron"
                                       Grid.Column="3"
                                       Text="&#xE76C;"
                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       FontSize="10"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{DynamicResource PopupMenuDisabledBrush}"
                                       Visibility="Collapsed" />

                            <Popup x:Name="PART_Popup"
                                   Placement="Right"
                                   HorizontalOffset="-4" VerticalOffset="-14"
                                   IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border Margin="10"
                                        Background="{DynamicResource PopupMenuBackgroundBrush}"
                                        BorderBrush="{DynamicResource PopupMenuBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="4"
                                        MinWidth="170">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="18" ShadowDepth="6" Direction="270" Opacity="0.30" Color="#000000" />
                                    </Border.Effect>
                                    <ScrollViewer Style="{DynamicResource {ComponentResourceKey ResourceId=MenuScrollViewer, TypeInTargetAssembly={x:Type FrameworkElement}}}">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{DynamicResource PopupMenuHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsSubmenuOpen" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{DynamicResource PopupMenuHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="CheckGlyph" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="Icon" Value="{x:Null}">
                            <Setter TargetName="IconHost" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="InputGestureText" Value="">
                            <Setter TargetName="Gesture" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="Role" Value="SubmenuHeader">
                            <Setter TargetName="Chevron" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource PopupMenuDisabledBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
